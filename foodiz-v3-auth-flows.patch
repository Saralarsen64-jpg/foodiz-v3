--- a/foodiz-v3/src/routes/ProtectedRoute.jsx
+++ b/foodiz-v3/src/routes/ProtectedRoute.jsx
@@ -3,7 +3,7 @@ import { useAuth } from '../components/auth/AuthProvider';
