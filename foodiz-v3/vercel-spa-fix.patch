From bb8e241cf5f92a55172169b49209cc8d25ef52c4 Mon Sep 17 00:00:00 2001
From: Foodiz Agent <agent@arena.ai>
Date: Thu, 14 May 2026 11:34:02 +0000
Subject: [PATCH] fix(vercel): add SPA rewrite so /auth, /client, /partner,
 /courier, /admin work on direct access

Without this, refreshing or directly opening any non-root route on
https://foodiz-v3.vercel.app returns 404 because Vercel tries to find a
matching static file. This rewrite tells Vercel to always serve
index.html and let the React Router (createBrowserRouter) resolve the
URL client-side.

Placed next to package.json so it is picked up regardless of whether
Vercel's Root Directory is set to the repo root or to foodiz-v3/.
---
 foodiz-v3/vercel.json | 8 ++++++++
 1 file changed, 8 insertions(+)
 create mode 100644 foodiz-v3/vercel.json

diff --git a/foodiz-v3/vercel.json b/foodiz-v3/vercel.json
new file mode 100644
index 0000000..1323cda
--- /dev/null
+++ b/foodiz-v3/vercel.json
@@ -0,0 +1,8 @@
+{
+  "rewrites": [
+    {
+      "source": "/(.*)",
+      "destination": "/index.html"
+    }
+  ]
+}
-- 
2.47.3

